server {
    listen 80;
    listen [::]:80;
    server_name weather.blaik.net www.weather.blaik.net;
    return 301 https://weather.blaik.net$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name weather.blaik.net www.weather.blaik.net;

    ssl_certificate /etc/ssl/certs/blaik.net.pem;
    ssl_certificate_key /etc/ssl/private/blaik.net.key;

    add_header X-Robots-Tag "noindex, nofollow, nosnippet, noarchive" always;

#    root /home/blaikey/weewx-data/public_html;
    root /var/www/weather;
    index index.php index.html index.htm;

    error_log /var/log/nginx/weewx.error_log error;

    location / {
        try_files $uri $uri/ =404;
        autoindex off;
    }

    # Main WeeWX dashboard
    location /weewx/ {
        alias /home/blaikey/weewx-data/public_html/;
        index index.html index.htm;
    }

    # Belchertown
    location /belchertown/ {
        alias /home/blaikey/weewx-data/public_html/belchertown/;
        index index.html index.htm;
    }

    # WH2900
    location /wh2900/ {
        alias /home/blaikey/weewx-data/public_html/wh2900/;
        index index.html index.htm;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
    }

    location ~ /\.ht {
        deny all;
    }
}